<div class="modal fade" id="addPasswordModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-3 shadow">
            <div class="modal-header border-bottom pb-3">
                <h6 class="fw-bold text-dark m-0">Add Credentials</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form method="post" asp-controller="Home" asp-action="Create">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label small fw-semibold text-muted">Title</label>
                        <input type="text" class="form-control" name="Title"
                               placeholder="e.g. Google Workspace, AWS Portal" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold text-muted">Website URL</label>
                        <input type="url" class="form-control" name="WebsiteUrl"
                               placeholder="https://..." required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold text-muted">Username / Email</label>
                        <input type="text" class="form-control" name="Username"
                               placeholder="username[at]domain.com" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold text-muted">Password</label>
                        <input type="password" class="form-control" name="Password" id="addPasswordInput"
                               placeholder="Enter key value" required>
                        <div class="progress mt-2" style="height: 4px;">
                            <div class="progress-bar" id="addStrengthMeter" role="progressbar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="4"></div>
                        </div>
                        <div class="small mt-1 fw-semibold text-end" id="addStrengthText"></div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold text-muted">Category</label>
                        <select class="form-select" name="Category">
                            <option value="Personal">Personal</option>
                            <option value="Work">Work</option>
                            <option value="Finance">Finance</option>
                            <option value="Development">Development</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary-custom w-100 py-2 mt-2">
                        Commit to Database
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

