@{
    var loginHistory = ViewData["LoginHistory"] as System.Collections.IEnumerable;
    var historyCount = 0;
}

<div class="modal fade" id="loginHistoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-3 shadow">
            <div class="modal-header border-bottom pb-3">
                <h6 class="fw-bold text-dark m-0">
                    <i class="bi bi-clock-history me-2"></i>Login History
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div class="login-history-header">
                    <i class="bi bi-clock-history me-1"></i> Recent Access Events
                </div>

                @if (loginHistory != null)
                {
                    foreach (var e in loginHistory)
                    {
                        historyCount++;
                        dynamic d = e!;
                        <div class="login-history-item">
                            <div class="d-flex align-items-start gap-2">
                                <div class="login-dot @(d.DotClass) mt-1"></div>
                                <div class="flex-grow-1">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <span style="font-size: 0.82rem; font-weight: 600; color: #0f172a;">@d.Title</span>
                                        <span class="text-muted" style="font-size: 0.72rem;">@d.RelativeTime</span>
                                    </div>
                                    <div class="text-muted" style="font-size: 0.76rem;">@d.Details</div>
                                </div>
                            </div>
                        </div>
                    }
                }

                @if (historyCount == 0)
                {
                    <div class="p-3 text-muted small">
                        No recent login activity yet.
                    </div>
                }

                <div style="padding: 0.5rem 1rem; background-color: #f8fafc; border-top: 1px solid #e2e8f0; text-align: center;">
                    <span class="text-muted" style="font-size: 0.72rem;">Showing last @historyCount events</span>
                </div>
            </div>
        </div>
    </div>
</div>

