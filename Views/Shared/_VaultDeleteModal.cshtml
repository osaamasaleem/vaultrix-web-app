<div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 rounded-3 shadow">
            <div class="modal-body text-center p-4">
                <div class="modal-danger-icon mb-3">
                    <i class="bi bi-trash3" style="font-size: 1.5rem; color: #ef4444;"></i>
                </div>
                <h6 class="fw-bold text-dark mb-1">Delete Credential?</h6>
                <p class="text-muted small mb-1">You are about to permanently delete:</p>
                <p class="fw-semibold text-dark mb-3" id="deleteItemTitle" style="font-size: 0.95rem;"></p>
                <p class="text-muted mb-0"
                   style="font-size: 0.78rem; background: #fef2f2; border-radius: 6px;
                          padding: 0.5rem 0.75rem; border: 1px solid #fee2e2;">
                    <i class="bi bi-exclamation-triangle-fill text-danger me-1"></i>
                    This action cannot be undone.
                </p>
                <form method="post" asp-controller="Home" asp-action="Delete" id="deleteForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" id="deleteItemId">
                    <div class="d-flex gap-2 mt-3">
                        <button type="button" class="btn btn-outline-secondary w-50 py-2"
                                data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger w-50 py-2">
                            <i class="bi bi-trash3 me-1"></i> Delete
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

