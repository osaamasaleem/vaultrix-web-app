<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Vaultrix</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    @await RenderSectionAsync("Styles", required: false)
</head>
<body data-toast-message="@(TempData["ToastMessage"] ?? "")"
      data-toast-type="@(TempData["ToastType"] ?? "")">
    <header class="sticky-top">
        <nav id="mainNavbar" class="navbar navbar-expand-sm navbar-light py-3">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-shield-lock-fill text-accent"></i> Vaultrix
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    @if (ViewData["Title"]?.ToString() == "My Vault")
                    {
                        <!-- Dashboard Navbar: Session status + User info + Logout -->
                        <ul class="navbar-nav flex-grow-1 justify-content-center gap-3">
                            <li class="nav-item">
                                <span class="nav-link text-success d-flex align-items-center gap-1">
                                    <i class="bi bi-patch-check-fill"></i> Session Encrypted
                                </span>
                            </li>
                        </ul>

                        <div class="d-flex align-items-center gap-2">
                            <!-- User Info -->
                            <span class="text-muted small d-none d-md-inline ms-1">
                                <i class="bi bi-person-circle"></i> @(ViewData["UserEmail"] ?? "user@example.com")
                            </span>

                            <!-- Logout -->
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm px-3 rounded-pill">
                                <i class="bi bi-box-arrow-right"></i> Log Out
                                </button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <ul class="navbar-nav flex-grow-1 justify-content-center gap-3">
                            <li class="nav-item">
                                <a class="nav-link" href="#features">Features</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="#security">Security</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="#faq">FAQ</a>
                            </li>
                        </ul>
                        <div class="d-flex gap-2">
                            <a class="btn btn-outline-custom" asp-controller="Account" asp-action="Login">Log In</a>
                            <a class="btn btn-primary-custom" asp-controller="Account" asp-action="Register">Get Started</a>
                        </div>
                    }

                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1100;">
        <div id="globalToast" class="toast align-items-center border-0 shadow" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body fw-semibold" id="globalToastMessage">
                </div>
                <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>

    <footer class="py-4 mt-5 text-center border-top" style="background-color: #f8fafc; border-color: #e2e8f0;">
        <div class="container text-muted">
            <p class="mb-1">&copy; @DateTime.Now.Year Vaultrix. All rights reserved.</p>
            <small>Industry standard credential protection.</small>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/zxcvbn/4.4.2/zxcvbn.js"></script>
    <script src="~/js/crypto.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/layout.js" asp-append-version="true"></script>
    <script src="~/js/auth.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
