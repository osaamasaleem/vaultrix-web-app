<div class="modal fade" id="generatorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-3 shadow">
            <div class="modal-header border-bottom pb-3">
                <h6 class="fw-bold text-dark m-0">Entropy Engine (Password Generator)</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <div class="input-group">
                        <input type="text"
                               class="form-control form-control-lg text-center font-monospace bg-light text-dark fw-bold"
                               readonly id="generatedPass" value="Configure requirements..."
                               style="font-size: 1.1rem; border-color: #e5e5e5;">
                        <button class="btn btn-outline-secondary" type="button"
                                id="copyPassBtn" style="border-color: #e5e5e5;">
                            <i class="bi bi-copy"></i>
                        </button>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-semibold text-muted d-flex justify-content-between">
                        <span>Entropy Length: <strong id="lenValue">16</strong> bits</span>
                    </label>
                    <input type="range" class="form-range" min="8" max="32" value="16" id="passLen">
                </div>
                <div class="mb-3 form-check">
                    <input type="checkbox" class="form-check-input" id="includeNumbers" checked>
                    <label class="form-check-label text-muted small" for="includeNumbers">
                        Numeric values (0-9)
                    </label>
                </div>
                <div class="mb-3 form-check">
                    <input type="checkbox" class="form-check-input" id="includeSymbols" checked>
                    <label class="form-check-label text-muted small" for="includeSymbols">
                        Symbols &amp; Special chars (!@@#$%)
                    </label>
                </div>
                <button type="button" class="btn btn-primary-custom w-100 py-2" id="generateBtn">
                    Generate Password
                </button>
            </div>
        </div>
    </div>
</div>

