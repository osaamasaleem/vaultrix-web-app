@{
    ViewData["Title"] = "Create Vault";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
}

<div class="container py-5">
    <div class="row justify-content-center align-items-center min-vh-75">
        <div class="col-md-5">
            <div class="card border-0 shadow p-4 p-md-5 rounded-4">
                <div class="text-center mb-4">
                    <i class="bi bi-shield-plus text-accent" style="font-size: 2.5rem;"></i>
                    <h3 class="fw-bold mt-2 text-dark">Create Your Vault</h3>
                    <p class="text-muted small">Start protecting your digital identity</p>
                </div>

                <form asp-controller="Account" asp-action="Register" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="EncryptedMekByPassword" id="mekByPassword" />
                    <input type="hidden" name="EncryptedMekByRecovery" id="mekByRecovery" />
                    <div class="mb-3">
                        <label for="email" class="form-label small fw-semibold text-muted">Email Address</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-envelope"></i></span>
                            <input type="email" class="form-control border-start-0 ps-0" id="email" name="Email" placeholder="name@example.com" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="password" class="form-label small fw-semibold text-muted">Master Password</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-key"></i></span>
                            <input type="password" class="form-control border-start-0 border-end-0 ps-0" id="password" name="Password" placeholder="Must be at least 12 characters" minlength="12" required>
                            <button class="btn btn-outline-secondary border-start-0 bg-white text-muted"
                                    type="button"
                                    data-toggle-password
                                    data-target="#password"
                                    data-icon="#toggleIcon">
                                <i id="toggleIcon" class="bi bi-eye"></i>
                            </button>
                        </div>
                        <div class="form-text small text-muted mt-1">
                            ⚠️ This password decrypts your vault. If lost, it cannot be recovered.
                        </div>
                        <div class="progress mt-2" style="height: 4px;">
                            <div class="progress-bar bg-danger" id="strengthMeter" role="progressbar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="4"></div>
                        </div>
                        <div class="small mt-1 fw-semibold text-end" id="strengthText"></div>
                    </div>

                    <div class="mb-4">
                        <label for="confirmPassword" class="form-label small fw-semibold text-muted">Confirm Master Password</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-check-circle"></i></span>
                            <input type="password" class="form-control border-start-0 ps-0" id="confirmPassword" name="ConfirmPassword" placeholder="Confirm your master key" required>
                        </div>
                    </div>

                    <div class="mb-4 form-check">
                        <input type="checkbox" class="form-check-input" id="terms" required>
                        <label class="form-check-label text-muted small" for="terms">
                            I understand that Vaultrix cannot recover my lost master password.
                        </label>
                    </div>

                    <button type="submit" class="btn btn-primary-custom w-100 py-2.5 mb-3">Create Free Vault</button>

                    <p class="text-center text-muted small mb-0">
                        Already have a vault? <a asp-controller="Account" asp-action="Login" class="text-accent fw-semibold text-decoration-none">Log In</a>
                    </p>
                </form>
            </div>
        </div>
<div class="modal fade" id="recoveryCodeModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-3 shadow">
            <div class="modal-header border-bottom pb-3">
                <h6 class="fw-bold text-dark m-0">Emergency Recovery Code</h6>
            </div>
            <div class="modal-body text-center">
                <p class="text-danger fw-bold small mb-2">⚠️ CRITICAL STEP</p>
                <p class="text-muted small">If you forget your Master Password, this code is the <strong>ONLY</strong> way to recover your vault. Write it down and keep it safe.</p>
                
                <div class="bg-light border rounded p-3 mb-3">
                    <code class="fs-4 text-dark fw-bold" id="displayRecoveryCode"></code>
                </div>
                
                <button type="button" class="btn btn-primary-custom w-100 py-2" id="confirmRecoveryBtn">
                    I have saved this code securely
                </button>
            </div>
        </div>
    </div>
</div>    </div>
</div>
