@{
    ViewData["Title"] = "Log In";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
}

<div class="container py-5">
    <div class="row justify-content-center align-items-center min-vh-75">
        <div class="col-md-5">
            <div class="card border-0 shadow p-4 p-md-5 rounded-4">
                <div class="text-center mb-4">
                    <i class="bi bi-shield-lock-fill text-accent" style="font-size: 2.5rem;"></i>
                    <h3 class="fw-bold mt-2 text-dark">Welcome Back</h3>
                    <p class="text-muted small">Access your secure vault</p>
                </div>

                <form asp-controller="Account" asp-action="Login" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label for="email" class="form-label small fw-semibold text-muted">Email Address</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-envelope"></i></span>
                            <input type="email" class="form-control border-start-0 ps-0" id="email" name="Email" placeholder="name@example.com" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between">
                            <label for="password" class="form-label small fw-semibold text-muted">Master Password</label>
                            <a asp-controller="Account" asp-action="Recover" class="text-accent small text-decoration-none">Forgot?</a>
                        </div>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-key"></i></span>
                            <input type="password" class="form-control border-start-0 border-end-0 ps-0" id="password" name="Password" placeholder="Enter your key" required>
                            <button class="btn btn-outline-secondary border-start-0 bg-white text-muted"
                                    type="button"
                                    data-toggle-password
                                    data-target="#password"
                                    data-icon="#toggleIcon">
                                <i id="toggleIcon" class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="mb-4 form-check">
                        <input type="checkbox" class="form-check-input" id="rememberMe" name="RememberMe" value="true">
                        <label class="form-check-label text-muted small" for="rememberMe">Keep my vault unlocked for 15 mins</label>
                    </div>

                    <button type="submit" class="btn btn-primary-custom w-100 py-2.5 mb-3">Unlock Vault</button>

                    <p class="text-center text-muted small mb-0">
                        New to Vaultrix? <a asp-controller="Account" asp-action="Register" class="text-accent fw-semibold text-decoration-none">Create an account</a>
                    </p>
                </form>
            </div>
        </div>
    </div>
</div>
