@model IEnumerable<PasswordManager.Models.VaultItem>

@{
    ViewData["Title"] = "My Vault";
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
}

<div class="container-fluid py-4 dashboard-container" style="max-width: 1400px;">
    <div class="row">

        <!-- Sidebar -->
        <div class="col-md-3 col-lg-2 mb-4">
            <div class="card border-0 bg-white p-2 shadow-sm rounded-3">
                <nav class="d-flex flex-column gap-1">
                    <a href="#" class="sidebar-link active js-sidebar-view" data-view="all">
                        <i class="bi bi-safe2"></i> All Vaults
                    </a>
                    <a href="#" class="sidebar-link js-sidebar-view" data-view="favorites">
                        <i class="bi bi-star"></i> Favorites
                    </a>
                    <a href="#" class="sidebar-link" data-bs-toggle="modal" data-bs-target="#loginHistoryModal">
                        <i class="bi bi-clock-history"></i> Login History
                    </a>
                    <hr class="text-muted my-2">
                    <a href="#" class="sidebar-link" data-bs-toggle="modal" data-bs-target="#generatorModal">
                        <i class="bi bi-cpu" style="color: #0d9488;"></i> Key Generator
                    </a>
                    <a href="#" class="sidebar-link" data-bs-toggle="modal" data-bs-target="#settingsModal">
                        <i class="bi bi-gear-fill text-secondary"></i> Settings
                    </a>
                </nav>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-md-9 col-lg-10">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
                <div>
                    <h2 class="fw-bold text-dark m-0" style="letter-spacing: -0.03em;">Personal Credentials</h2>
                    <p class="text-muted small m-0">Secure storage powered by client-side PBKDF2 cryptography.</p>
                </div>
                <button class="btn btn-primary-custom d-flex align-items-center gap-2"
                        data-bs-toggle="modal" data-bs-target="#addPasswordModal">
                    <i class="bi bi-plus"></i> New Credential
                </button>
            </div>

            <!-- Search & Filter -->
            <input type="hidden" id="encryptedMekData" value="@ViewData["EncryptedMek"]" />
            <div class="card border-0 shadow-sm p-3 mb-4 rounded-3 bg-white">
                <div class="row g-2">
                    <div class="col-md-8">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-search"></i></span>
                            <input type="text" class="form-control border-start-0 ps-0"
                                   placeholder="Search parameters..." id="vaultSearch">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <select class="form-select" id="categoryFilter">
                            <option value="All">All Categories</option>
                            <option value="Work">Work</option>
                            <option value="Finance">Finance</option>
                            <option value="Development">Development</option>
                            <option value="Personal">Personal</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Vault Grid -->
            <div class="row g-3" id="vaultGrid">
                @foreach (var item in Model)
                {
                    <div class="col-xl-4 col-md-6 vault-item-card"
                         data-category="@item.Category"
                         data-title="@item.Title.ToLower()"
                         data-username="@item.Username.ToLower()"
                         data-favorite="@item.IsFavorite.ToString().ToLower()">
                        <div class="card vault-card h-100 p-3">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h6 class="fw-bold text-dark mb-0">@item.Title</h6>
                                <span class="badge-category">@item.Category</span>
                            </div>

                            <p class="small text-muted mb-3">
                                <a href="@item.WebsiteUrl" target="_blank" class="text-decoration-none"
                                   style="color: #0d9488; font-weight: 500;">@item.WebsiteUrl</a>
                            </p>

                            <div class="mb-3">
                                <label class="form-label text-muted mb-0" style="font-size: 0.75rem; font-weight: 600;">IDENTITY</label>
                                <div class="text-dark" style="font-size: 0.9rem; font-weight: 500;">@item.Username</div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label text-muted mb-0" style="font-size: 0.75rem; font-weight: 600;">PASSWORD</label>
                                <div class="input-group mt-1">
                                    <input type="password"
                                           class="form-control form-control-sm border-end-0 bg-light text-secondary"
                                           value="@item.Password" readonly
                                           id="pass-@item.Id" style="font-family: monospace;">
                                    @* FIX (XSS): data-toggle-id instead of onclick with inline parameter *@
                                    <button class="btn btn-outline-secondary btn-sm bg-light border-start-0 text-muted"
                                            type="button"
                                            data-toggle-id="@item.Id"
                                            style="border-color: #e5e5e5;">
                                        <i id="eye-@item.Id" class="bi bi-eye"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="d-flex gap-2 justify-content-end border-top pt-2 mt-auto"
                                 style="border-color: #f5f5f5 !important;">
                                @*
                                    FIX (XSS): All item values stored in data-* attributes.
                                    Razor's default encoding makes these XSS-safe automatically.
                                    JS reads them via dataset — zero inline parameter injection.
                                *@
                                <button class="btn btn-sm text-secondary p-0 js-edit-btn"
                                        style="font-size: 0.8rem; font-weight: 500;"
                                        data-id="@item.Id"
                                        data-title="@item.Title"
                                        data-url="@item.WebsiteUrl"
                                        data-username="@item.Username"
                                        data-password="@item.Password"
                                        data-category="@item.Category">
                                    Edit
                                </button>
                                <div class="vr text-muted" style="height: 14px; margin-top: 4px;"></div>
                                <button class="btn btn-sm text-danger p-0 js-delete-btn"
                                        style="font-size: 0.8rem; font-weight: 500;"
                                        data-id="@item.Id"
                                        data-title="@item.Title">
                                    Delete
                                </button>
                                <div class="vr text-muted" style="height: 14px; margin-top: 4px;"></div>
                                <form method="post" asp-controller="Home" asp-action="ToggleFavorite" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm p-0 favorite-btn @(item.IsFavorite ? "is-favorite" : "")" title="@(item.IsFavorite ? "Remove from favorites" : "Add to favorites")">
                                        <i class="bi @(item.IsFavorite ? "bi-star-fill" : "bi-star")"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>

        </div>
    </div>
</div>

@await Html.PartialAsync("_VaultAddModal")
@await Html.PartialAsync("_VaultEditModal")
@await Html.PartialAsync("_VaultDeleteModal")
@await Html.PartialAsync("_PasswordGeneratorModal")
@await Html.PartialAsync("_LoginHistoryModal")
@await Html.PartialAsync("_SettingsModal")

@section Scripts {
    <script src="~/js/dashboard.js" asp-append-version="true"></script>
}
