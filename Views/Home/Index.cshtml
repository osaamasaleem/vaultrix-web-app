@{
    ViewData["Title"] = "Secure Password Manager";
}

<section class="py-5 text-center" style="background-color: #f8fafc; border-bottom: 1px solid #e2e8f0;">
    <div class="container py-5">
        <h1 class="display-4 fw-bold text-dark mb-3">Your Digital Life, <br><span class="text-accent">Safely Secured.</span></h1>
        <p class="lead text-muted mx-auto mb-4" style="max-width: 650px;">
            Vaultrix stores your passwords, secure notes, and personal data in a clean, encrypted digital vault. Access your secrets securely from any browser.
        </p>
        <div class="d-flex justify-content-center gap-3">
    <a asp-controller="Account" asp-action="Register" class="btn btn-primary-custom btn-lg px-4 py-2.5">Create Free Vault</a>
    <a href="#features" class="btn btn-outline-custom btn-lg px-4 py-2.5">How It Works</a>
</div>
    </div>
</section>

<section id="features" class="py-5">
    <div class="container py-5">
        <div class="text-center mb-5">
            <h2 class="fw-bold text-dark">Why Choose Vaultrix</h2>
            <p class="text-muted">A minimal, secure, and intuitive tool for managing your online credentials.</p>
        </div>
        
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 p-4 shadow-sm" style="background-color: #f8fafc;">
                    <div class="text-accent mb-3">
                        <i class="bi bi-shield-fill-check fs-2"></i>
                    </div>
                    <h5 class="fw-bold">Robust Encryption</h5>
                    <p class="text-muted mb-0 small">Your data is secured locally using standard AES-256 encryption before it's sent anywhere.</p>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="card h-100 border-0 p-4 shadow-sm" style="background-color: #f8fafc;">
                    <div class="text-accent mb-3">
                        <i class="bi bi-key-fill fs-2"></i>
                    </div>
                    <h5 class="fw-bold">Zero-Knowledge</h5>
                    <p class="text-muted mb-0 small">Only you hold the key. We cannot read your master password or access your vault contents.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 border-0 p-4 shadow-sm" style="background-color: #f8fafc;">
                    <div class="text-accent mb-3">
                        <i class="bi bi-lightning-charge-fill fs-2"></i>
                    </div>
                    <h5 class="fw-bold">Smart Generator</h5>
                    <p class="text-muted mb-0 small">Instantly generate long, complex, and un-guessable credentials with the click of a button.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="security" class="py-5" style="background-color: #f8fafc; border-top: 1px solid #e2e8f0; border-bottom: 1px solid #e2e8f0;">
    <div class="container py-5">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h2 class="fw-bold text-dark display-6 mb-3">We respect your privacy.</h2>
                <p class="text-muted">
                    We built Vaultrix with local security first. This means your vault data is encrypted inside your browser. If someone gains unauthorized access to our storage, they only see scrambled ciphertext that is impossible to read without your master key.
                </p>
            </div>
            <div class="col-lg-6 text-center">
                <i class="bi bi-shield-lock-fill text-accent" style="font-size: 8rem; opacity: 0.9;"></i>
            </div>
        </div>
    </div>
</section>

<section id="faq" class="py-5">
    <div class="container py-5" style="max-width: 800px;">
        <h2 class="fw-bold text-center text-dark mb-5">Frequently Asked Questions</h2>
        
        <div class="accordion border-0" id="faqAccordion">
            <div class="accordion-item border mb-3 rounded shadow-sm">
                <h2 class="accordion-header" id="headingOne">
                    <button class="accordion-button bg-white text-dark fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
                        How is my master password protected?
                    </button>
                </h2>
                <div id="collapseOne" class="accordion-collapse collapse show" aria-labelledby="headingOne" data-bs-parent="#faqAccordion">
                    <div class="accordion-body text-muted">
                        Your master password is encrypted using PBKDF2 hashing locally. It is never transmitted directly to our servers, keeping your primary key secret.
                    </div>
                </div>
            </div>

            <div class="accordion-item border mb-3 rounded shadow-sm">
                <h2 class="accordion-header" id="headingTwo">
                    <button class="accordion-button bg-white text-dark collapsed fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
                        Can Vaultrix recover my account if I lose my Master Password?
                    </button>
                </h2>
                <div id="collapseTwo" class="accordion-collapse collapse" aria-labelledby="headingTwo" data-bs-parent="#faqAccordion">
                    <div class="accordion-body text-muted">
                        Because of our strict zero-knowledge security, we do not know or store your master password. If lost, your vault cannot be decrypted.
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
